# Doxyfile for LE Audio Manager

PROJECT_NAME           = "LE Audio Manager"
PROJECT_BRIEF          = "LE Audio Manager Library based on BlueZ D-Bus"
OUTPUT_DIRECTORY       = doc
CREATE_SUBDIRS         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_TIMESTAMP         = YES
HTML_DYNAMIC_MENUS     = YES
HTML_INDEX_NUM_ENTRIES = 50

INPUT                  = inc
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h
RECURSIVE              = NO
EXCLUDE                =

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"
